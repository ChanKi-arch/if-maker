# IF Maker — Optional LLM enhancement (BYOK)
#
# Leave LLM_API_KEY blank to run IF Maker in pure deterministic mode.
# Fill it in to enable the optional "LLM enhance" toggle in the UI.
#
# Works with any OpenAI SDK-compatible endpoint:
#   - OpenAI       → https://api.openai.com/v1            (e.g. gpt-4o-mini)
#   - DeepSeek     → https://api.deepseek.com/v1          (e.g. deepseek-chat)
#   - Groq         → https://api.groq.com/openai/v1       (e.g. llama-3.1-70b-versatile)
#   - Alibaba Qwen → https://dashscope.aliyuncs.com/compatible-mode/v1  (e.g. qwen-plus)
#   - Local Ollama → http://localhost:11434/v1            (e.g. llama3.1)

LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
